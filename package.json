{
  "name": "viztechstack",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check:no-any": "node tooling/scripts/check-no-any.mjs",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky",
    "generate:module": "tsx tooling/scripts/generate-module.ts",
    "generate:feature": "tsx tooling/scripts/generate-feature.ts",
    "validate:deps": "tsx tooling/scripts/validate-deps.ts",
    "analyze:bundle": "tsx tooling/scripts/analyze-bundle.ts",
    "test:smoke:staging": "tsx tooling/scripts/smoke-tests.ts staging",
    "test:smoke:production": "tsx tooling/scripts/smoke-tests.ts production"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/glob": "^9.0.0",
    "@types/node": "^22.10.7",
    "@viztechstack/env": "workspace:*",
    "convex": "^1.32.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "prettier": "^3.5.0",
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@viztechstack/typescript-config": "workspace:*"
    }
  },
  "dependencies": {
    "graphql": "^16.13.0",
    "zod": "^3.25.76"
  }
}
